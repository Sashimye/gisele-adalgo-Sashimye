export const calculator = (x, y, operator) => {
    if (operator === "%") return "no operators";

    if (typeof x !== "number" || typeof y !== "number") {
        return "is empty";
    }

    switch (operator) {
        case "+":
            return x + y;
        case "-":
            return x - y;
        case "*":
            return x * y;
        case "/":
            return x / y;
        default:
            return "no operators";
    }
};
